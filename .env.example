VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Where the scraper service (server.js) is reachable from the browser.
# Leave unset in local dev — Vite proxies "/api" to localhost:3001 (vite.config.js).
# Set this to the deployed scraper's URL when deploying the SPA (e.g. Render/Fly/Railway).
VITE_SCRAPER_URL=

# Server-only — never prefix with VITE_, never ship to the client.
# Used only by scripts/import-json-to-supabase.mjs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# server.js only — the deployed SPA's origin(s), comma-separated, so CORS only
# allows your own frontend. Leave unset in local dev (falls back to wide-open).
FRONTEND_URL=
